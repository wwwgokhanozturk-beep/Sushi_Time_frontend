# Dev: оставь пустым — запросы идут через Vite proxy (/api → localhost:5000/api)
# Prod: укажи реальный URL сервера
# VITE_API_URL=https://your-server.com/api

# Mapbox public token (pk.*). Реальное значение НЕ коммитим:
#  - локально: web_client/.env.local
#  - прод: переменная VITE_MAPBOX_TOKEN в настройках Vercel
VITE_MAPBOX_TOKEN=
